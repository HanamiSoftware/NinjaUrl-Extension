{
  "manifest_version": 3,
  "name": "NinjaUrl",
  "version": "2.0",
  "action": {
    "default_title": "NinjaUrl",
    "default_icon": {
      "16": "dist/assets/icons/icon16.png",
      "48": "dist/assets/icons/icon48.png",
      "128": "dist/assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background/index.js",
    "type": "module"
  },
  "host_permissions": [
    "https://ninjaurl.io/*",
    "https://api.ninjaurl.io/*",
    "https://auth.ninjaurl.io/*",
    "https://n2l.ink/*"
  ],

  "permissions": [
    "storage",
    "activeTab",
    "clipboardWrite",
    "sidePanel",
    "notifications",
    "identity",
    "tabs"
  ],
  "side_panel": {
    "default_path": "dist/panel/sidepanel.html"
  },
  "icons": {
    "16": "dist/assets/icons/icon16.png",
    "48": "dist/assets/icons/icon48.png",
    "128": "dist/assets/icons/icon128.png"
  }
}
